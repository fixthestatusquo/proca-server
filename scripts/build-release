#!/bin/sh
# Build a production release of Proca.
#
# Prerequisites: asdf with elixir 1.14.4 / erlang 25.2.2 (see .tool-versions)
#
# Usage:  MIX_ENV=prod ./scripts/build-release
#
# Produces a release under _build/prod/rel/proca/.
# Deploy with: ./scripts/deploy-simple <version>

set -euo pipefail

export MIX_ENV="${MIX_ENV:-prod}"

echo "==> Getting dependencies"
mix deps.get --only prod

echo "==> Compiling dependencies"
mix deps.compile

echo "==> Compiling application"
mix compile --warnings-as-errors

echo "==> Building static assets"
mix phx.digest
mix assets.deploy

echo "==> Assembling release"
mix release --overwrite

echo "==> Done"
echo "Release built at _build/prod/rel/proca/"
grep -oP 'version: "\K[^"]+' mix.exs
