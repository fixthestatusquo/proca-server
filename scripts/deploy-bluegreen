#!/bin/bash
# Zero-downtime deploy to live by switching the nginx upstream.
#
# Assumes ./scripts/release was already run.
#
# Usage:  ./scripts/deploy-bluegreen [version]

set -euo pipefail

VERSION="${1:-}"
if [ -z "$VERSION" ]; then
  VERSION=$(grep -oP 'version: "\K[^"]+' mix.exs)
fi

RELEASE_DST="/srv/proca/releases/proca-${VERSION}"
CURRENT_LINK="/srv/proca/live"
ENV_FILE="/etc/proca/env.live"
BLUE_PORT=4001
GREEN_PORT=4011
SERVICE_PREFIX="proca-live"
NGINX_UPSTREAM_CONF="/etc/nginx/sites-enabled/proca-live"

# ---- Verify release exists ----
if [ ! -d "$RELEASE_DST" ]; then
  echo "ERROR: Release not found at ${RELEASE_DST}"
  echo "Run ./scripts/release first"
  exit 1
fi

# ---- Verify symlink points to this version ----
if [ "$(readlink -f "$CURRENT_LINK")" != "$RELEASE_DST" ]; then
  echo "==> Updating symlink to ${RELEASE_DST}"
  ln -sfn "$RELEASE_DST" "$CURRENT_LINK"
else
  echo "==> Symlink already points to ${RELEASE_DST}"
fi

# ---- Migrate ----
echo "==> Running database migrations"
sudo bash -c "set -a; . ${ENV_FILE}; ${RELEASE_DST}/bin/proca eval Proca.ReleaseTasks.migrate"

# ---- Determine which instance is currently active ----
ACTIVE_INSTANCE=""
if systemctl is-active --quiet "${SERVICE_PREFIX}-blue" 2>/dev/null; then
  ACTIVE_INSTANCE="blue"
  ACTIVE_PORT="$BLUE_PORT"
elif systemctl is-active --quiet "${SERVICE_PREFIX}-green" 2>/dev/null; then
  ACTIVE_INSTANCE="green"
  ACTIVE_PORT="$GREEN_PORT"
else
  echo "ERROR: No active live instance found."
  echo "Start one first: sudo systemctl start ${SERVICE_PREFIX}-blue"
  exit 1
fi

STANDBY_INSTANCE=$([ "$ACTIVE_INSTANCE" = "blue" ] && echo "green" || echo "blue")
STANDBY_PORT=$([ "$STANDBY_INSTANCE" = "blue" ] && echo "$BLUE_PORT" || echo "$GREEN_PORT")

echo "==> Active:  ${SERVICE_PREFIX}-${ACTIVE_INSTANCE}  (port ${ACTIVE_PORT})"
echo "==> Standby: ${SERVICE_PREFIX}-${STANDBY_INSTANCE} (port ${STANDBY_PORT})"

# ---- Start the standby instance ----
echo "==> Starting standby instance"
sudo systemctl start "${SERVICE_PREFIX}-${STANDBY_INSTANCE}"

echo "==> Waiting for standby to pass health check..."
HEALTHY=false
for i in $(seq 1 30); do
  if curl -sf "http://127.0.0.1:${STANDBY_PORT}/health" >/dev/null 2>&1; then
    HEALTHY=true
    echo "   Healthy after ${i}s"
    break
  fi
  sleep 1
done

if [ "$HEALTHY" != "true" ]; then
  echo "ERROR: Standby did not become healthy."
  echo "  Check: sudo journalctl -u ${SERVICE_PREFIX}-${STANDBY_INSTANCE} -f"
  sudo systemctl stop "${SERVICE_PREFIX}-${STANDBY_INSTANCE}" 2>/dev/null || true
  exit 1
fi

# ---- Swap nginx upstream ----
echo "==> Swapping nginx: port ${STANDBY_PORT} → primary, port ${ACTIVE_PORT} → backup"
if [ -f "$NGINX_UPSTREAM_CONF" ]; then
  sudo sed -i \
    -e "s/${ACTIVE_PORT}/__TMP__/g" \
    -e "s/${STANDBY_PORT}/${ACTIVE_PORT}/g" \
    -e "s/__TMP__/${STANDBY_PORT}/g" \
    "$NGINX_UPSTREAM_CONF"
  sudo nginx -s reload
  echo "   nginx reloaded."
else
  echo "   Config not found at ${NGINX_UPSTREAM_CONF}"
  echo "   Update it manually and run: sudo nginx -s reload"
fi

# ---- Stop the old instance ----
echo "==> Stopping old instance: ${SERVICE_PREFIX}-${ACTIVE_INSTANCE}"
sudo systemctl stop "${SERVICE_PREFIX}-${ACTIVE_INSTANCE}"

# Final health check
sleep 2
echo "==> Verifying new primary is healthy..."
if curl -sf "http://127.0.0.1:${STANDBY_PORT}/health" >/dev/null 2>&1; then
  echo "   Healthy."
else
  echo "WARNING: Health check failed after swap."
  echo "  Check: sudo journalctl -u ${SERVICE_PREFIX}-${STANDBY_INSTANCE} -f"
fi

echo ""
echo "==> Deploy complete!"
echo "   Version: ${VERSION}"
echo "   Active:  ${SERVICE_PREFIX}-${STANDBY_INSTANCE} (port ${STANDBY_PORT})"
