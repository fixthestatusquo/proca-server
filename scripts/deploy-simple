#!/bin/bash
# Deploy a built release and restart the service.
#
# Usage:  ./scripts/deploy-simple [version] [staging|live]
#
# Examples:
#   ./scripts/deploy-simple                  # uses mix.exs version, deploys to staging
#   ./scripts/deploy-simple 3.9.16 live      # explicit version, deploys to live

set -euo pipefail

# ---- Which environment? ----
ENV="${2:-staging}"

case "$ENV" in
  staging)
    CURRENT_LINK="/srv/proca/current"
    ENV_FILE="/etc/proca/env"
    SERVICE="proca"
    PORT=4000
    ;;
  live)
    CURRENT_LINK="/srv/proca/live"
    ENV_FILE="/etc/proca/env.live"
    SERVICE="proca-live"
    PORT=4001
    ;;
  *)
    echo "ERROR: unknown environment '$ENV'. Use staging or live."
    exit 1
    ;;
esac

echo "==> Environment: ${ENV}"

# ---- Version ----
VERSION="${1:-}"
if [ -z "$VERSION" ]; then
  VERSION=$(grep -oP 'version: "\K[^"]+' mix.exs)
  echo "==> No version specified, extracted from mix.exs: ${VERSION}"
fi

RELEASE_SRC="_build/prod/rel/proca"
RELEASE_DST="/srv/proca/releases/proca-${VERSION}"

if [ ! -d "$RELEASE_SRC" ]; then
  echo "ERROR: Release not found at $RELEASE_SRC"
  echo "Run ./scripts/build-release first"
  exit 1
fi

echo "==> Copying release to $RELEASE_DST"
mkdir -p "$(dirname "$RELEASE_DST")"
rsync -avz --delete "$RELEASE_SRC/" "$RELEASE_DST/"

echo "==> Updating current symlink (atomic)"
ln -sfn "$RELEASE_DST" "$CURRENT_LINK"

echo "==> Running database migrations"
# Run as root because /etc/proca/env is root-readable only
sudo sh -c ". ${ENV_FILE} && ${RELEASE_DST}/bin/proca eval Proca.ReleaseTasks.migrate"

echo "==> Restarting service: ${SERVICE}"
sudo systemctl restart "$SERVICE"

echo "==> Done"
echo "Deployed version ${VERSION} to ${ENV}. Waiting for health check..."
sleep 3

if curl -sf "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
  echo "Service is healthy."
else
  echo "WARNING: Health check failed. Check logs with: journalctl -u ${SERVICE} -f"
fi
